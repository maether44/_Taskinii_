  formEl.textContent='вЂ”'; formEl.style.color='var(--text-dim)';
  scoreValEl.textContent='вЂ”'; scoreValEl.style.color='var(--text-dim)';
  scoreFillEl.style.width='0%';
  phaseValEl.textContent='READY'; angleValEl.textContent='вЂ”';
