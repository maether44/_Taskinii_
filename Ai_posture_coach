<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AI Posture Coach Pro</title>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/drawing_utils/drawing_utils.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js" crossorigin="anonymous"></script>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#07090d;--bg2:#0c1018;--bg3:#111820;--panel:#0a0f16;
  --border:#1a2535;--border2:#243040;
  --green:#00ff88;--green2:#00cc6a;--green-glow:rgba(0,255,136,.25);
  --red:#ff3355;--red-glow:rgba(255,51,85,.25);
  --amber:#ffaa00;--amber-glow:rgba(255,170,0,.2);
  --cyan:#00c8ff;--cyan-glow:rgba(0,200,255,.2);
  --text:#c8d8e8;--text-dim:#4a6a8a;--text-mid:#7a9ab8;
  --font-head:'Orbitron',monospace;
  --font-body:'Rajdhani',sans-serif;
  --font-mono:'Share Tech Mono',monospace;
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font-body);overflow-x:hidden}
#app{display:grid;grid-template-columns:1fr 340px;grid-template-rows:auto 1fr;grid-template-areas:"hdr hdr""feed panel";min-height:100vh}

/* HEADER */
header{grid-area:hdr;display:flex;align-items:center;justify-content:space-between;padding:10px 20px;gap:10px;flex-wrap:wrap;background:var(--bg2);border-bottom:1px solid var(--border);position:relative;z-index:20}
.logo{display:flex;align-items:center;gap:10px}
.logo-icon{width:34px;height:34px;border-radius:8px;background:linear-gradient(135deg,var(--green),var(--cyan));display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 0 18px var(--green-glow);flex-shrink:0}
.logo-text{font-family:var(--font-head);font-size:12px;font-weight:700;color:var(--green);letter-spacing:2px}
.logo-sub{font-family:var(--font-mono);font-size:8px;color:var(--text-dim);letter-spacing:2px;display:block;margin-top:2px}
.hdr-controls{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.ex-label{font-family:var(--font-mono);font-size:10px;color:var(--text-dim);letter-spacing:1px;white-space:nowrap}
select#exSel{background:var(--bg3);border:1px solid var(--border);color:var(--text);font-family:var(--font-mono);font-size:11px;padding:7px 10px;border-radius:6px;cursor:pointer;outline:none;min-width:150px;transition:border-color .2s}
select#exSel:focus{border-color:var(--green)}
select#exSel option{background:var(--bg2)}
.btn{font-family:var(--font-head);font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:8px 14px;border-radius:6px;border:1px solid;cursor:pointer;transition:all .2s;white-space:nowrap}
.btn-go{background:var(--green);border-color:var(--green);color:#000;box-shadow:0 0 14px var(--green-glow)}
.btn-go:hover{box-shadow:0 0 26px rgba(0,255,136,.5);transform:translateY(-1px)}
.btn-stop{background:transparent;border-color:var(--red);color:var(--red)}
.btn-stop:hover{background:var(--red-glow)}
.btn-ghost{background:transparent;border-color:var(--border);color:var(--text-dim)}
.btn-ghost:hover{border-color:var(--cyan);color:var(--cyan)}
.dot{width:7px;height:7px;border-radius:50%;background:var(--text-dim);transition:all .3s;flex-shrink:0}
.dot.live{background:var(--green);box-shadow:0 0 8px var(--green);animation:blink 1.6s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
.voice-btn{display:flex;align-items:center;gap:5px;padding:7px 10px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;cursor:pointer;transition:all .2s;font-family:var(--font-mono);font-size:9px;color:var(--text-dim)}
.voice-btn.on{border-color:var(--amber);color:var(--amber);background:var(--amber-glow)}

/* FEED */
#feedArea{grid-area:feed;position:relative;background:#000;display:flex;align-items:center;justify-content:center;overflow:hidden;min-height:400px}
#vid{position:absolute;width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
#cvs{position:absolute;width:100%;height:100%;object-fit:cover;transform:scaleX(-1)}
#placeholder{display:flex;flex-direction:column;align-items:center;gap:14px;z-index:2;text-align:center;padding:20px}
.ph-icon{font-size:52px;opacity:.25}
.ph-txt{font-family:var(--font-mono);font-size:11px;color:var(--text-dim);line-height:2}
#scoreOverlay{position:absolute;top:14px;left:14px;z-index:6;background:rgba(7,9,13,.82);border:1px solid var(--border);border-radius:10px;padding:10px 14px;backdrop-filter:blur(6px);min-width:108px}
.ov-lbl{font-family:var(--font-mono);font-size:9px;color:var(--text-dim);letter-spacing:2px;text-transform:uppercase;margin-bottom:3px}
.ov-val{font-family:var(--font-head);font-size:30px;font-weight:900;line-height:1;transition:color .3s}
.ov-bar{height:3px;background:var(--border);border-radius:2px;margin-top:5px;overflow:hidden}
.ov-fill{height:100%;border-radius:2px;transition:width .35s,background .3s}
#phaseOverlay{position:absolute;top:14px;right:14px;z-index:6;background:rgba(7,9,13,.82);border:1px solid var(--border);border-radius:10px;padding:10px 14px;backdrop-filter:blur(6px);text-align:right}
.phase-val{font-family:var(--font-head);font-size:12px;font-weight:700;color:var(--cyan);letter-spacing:1px}
.angle-val{font-family:var(--font-mono);font-size:11px;color:var(--text-dim);margin-top:2px}
#repFlash{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);font-family:var(--font-head);font-size:68px;font-weight:900;color:var(--green);text-shadow:0 0 40px var(--green),0 0 80px var(--green-glow);pointer-events:none;opacity:0;z-index:10;letter-spacing:4px}
#repFlash.pop{animation:repPop .65s cubic-bezier(.17,.67,.32,1.3) forwards}
@keyframes repPop{0%{transform:translate(-50%,-50%) scale(0);opacity:1}55%{transform:translate(-50%,-50%) scale(1.1);opacity:1}100%{transform:translate(-50%,-50%) scale(1.5);opacity:0}}
#restOverlay{position:absolute;inset:0;z-index:15;background:rgba(7,9,13,.93);backdrop-filter:blur(10px);display:none;flex-direction:column;align-items:center;justify-content:center;gap:12px}
#restOverlay.show{display:flex}
.rest-lbl{font-family:var(--font-mono);font-size:11px;color:var(--cyan);letter-spacing:3px;text-transform:uppercase}
.rest-time{font-family:var(--font-head);font-size:96px;font-weight:900;color:var(--cyan);line-height:1;text-shadow:0 0 40px var(--cyan-glow)}
.rest-sub{font-family:var(--font-body);font-size:16px;color:var(--text-mid)}
#fpsEl{position:absolute;bottom:10px;right:10px;font-family:var(--font-mono);font-size:9px;color:var(--text-dim);background:rgba(7,9,13,.6);padding:3px 7px;border-radius:4px;z-index:5}

/* PANEL */
#panel{grid-area:panel;background:var(--panel);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto}
.psec{padding:15px 17px;border-bottom:1px solid var(--border)}
.psec:last-child{border-bottom:none}
.psec-title{font-family:var(--font-mono);font-size:9px;color:var(--text-dim);letter-spacing:3px;text-transform:uppercase;margin-bottom:11px;display:flex;align-items:center;gap:8px}
.psec-title::before{content:'';display:block;width:14px;height:2px;background:var(--green);border-radius:1px}
.ex-name{font-family:var(--font-head);font-size:18px;font-weight:700;color:var(--text);margin-bottom:4px}
.ex-desc{font-size:12px;color:var(--text-dim);line-height:1.65}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
.scard{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:9px 11px;transition:border-color .3s}
.scard.hi{border-color:var(--green)}
.scard-lbl{font-family:var(--font-mono);font-size:8px;color:var(--text-dim);letter-spacing:2px;text-transform:uppercase;margin-bottom:3px}
.scard-val{font-family:var(--font-head);font-size:22px;font-weight:700;line-height:1;color:var(--green)}
.scard-val.dim{color:var(--text-dim)}
.set-row{display:flex;align-items:center;gap:7px;flex-wrap:wrap;margin-bottom:10px}
.set-dot{width:26px;height:26px;border-radius:50%;border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-family:var(--font-head);font-size:9px;color:var(--text-dim);transition:all .3s}
.set-dot.done{border-color:var(--green);background:rgba(0,255,136,.12);color:var(--green)}
.set-dot.active{border-color:var(--cyan);background:rgba(0,200,255,.1);color:var(--cyan);box-shadow:0 0 10px var(--cyan-glow)}
.set-config{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.set-config label{font-family:var(--font-mono);font-size:9px;color:var(--text-dim);letter-spacing:1px}
.set-config input{width:44px;background:var(--bg3);border:1px solid var(--border);color:var(--text);font-family:var(--font-mono);font-size:11px;padding:4px 6px;border-radius:5px;text-align:center;outline:none}
.set-config input:focus{border-color:var(--green)}
#cueBox{background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--amber);border-radius:6px;padding:11px 13px;font-size:14px;font-weight:600;color:var(--amber);line-height:1.5;min-height:50px;transition:color .3s,border-color .3s}
#cueBox.good{border-left-color:var(--green);color:var(--green)}
#jointList{display:flex;flex-direction:column;gap:7px}
.jitem{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;background:var(--bg3);border-radius:6px;border:1px solid var(--border);font-family:var(--font-mono);font-size:11px;transition:border-color .3s}
.jitem.ok{border-color:rgba(0,255,136,.22)}
.jitem.bad{border-color:rgba(255,51,85,.28)}
.jname{color:var(--text)}
.jangle{color:var(--text-dim);font-size:10px}
.jbadge{font-size:9px;padding:2px 7px;border-radius:20px;font-weight:700;letter-spacing:1px}
.jbadge.ok{background:rgba(0,255,136,.1);color:var(--green)}
.jbadge.bad{background:rgba(255,51,85,.1);color:var(--red)}

/* HEATMAP */
#heatmapWrap{display:flex;justify-content:center;padding:6px 0}
#heatmapSvg{width:130px;height:auto}
.hm-legend{margin-top:8px;display:flex;align-items:center;justify-content:center;gap:6px;font-family:var(--font-mono);font-size:9px;color:var(--text-dim)}
.hm-swatch{width:40px;height:4px;border-radius:3px;background:linear-gradient(90deg,var(--green),var(--amber),var(--red))}

/* PLANK TIMER shown in rep card */
#plankDisplay{display:none;font-family:var(--font-head);font-size:22px;font-weight:700;color:var(--cyan)}

#panel::-webkit-scrollbar{width:3px}
#panel::-webkit-scrollbar-track{background:var(--bg2)}
#panel::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}

@media(max-width:820px){
  #app{grid-template-columns:1fr;grid-template-rows:auto auto 1fr;grid-template-areas:"hdr""panel""feed"}
  #feedArea{min-height:55vh}
  #panel{max-height:45vh;border-left:none;border-top:1px solid var(--border)}
}
</style>
</head>
