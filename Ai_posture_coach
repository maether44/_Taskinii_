<script>
'use strict';

/* в”Ђв”Ђ UTILITIES в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
function angleBetween(A,B,C){
  const ax=A.x-B.x,ay=A.y-B.y,cx=C.x-B.x,cy=C.y-B.y;
  const dot=ax*cx+ay*cy, mag=Math.hypot(ax,ay)*Math.hypot(cx,cy);
  if(!mag) return 0;
  return Math.acos(Math.max(-1,Math.min(1,dot/mag)))*(180/Math.PI);
}
function heatColor(f){
  // f: 0=green, 0.5=amber, 1=red
  const r=f<.5?Math.round(f*2*255):255;
  const g=f<.5?255:Math.round((1-(f-.5)*2)*170);
  return `rgba(${r},${g},0,0.75)`;
}

/* в”Ђв”Ђ VOICE COACHING в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
let voiceEnabled  = true;
let lastSpokenTxt = '';
let lastSpeakTime = 0;
const SPEAK_GAP   = 4500;

function speak(text){
  if(!voiceEnabled||!window.speechSynthesis) return;
  const now=Date.now();
  if(text===lastSpokenTxt && now-lastSpeakTime<SPEAK_GAP) return;
  lastSpokenTxt=text; lastSpeakTime=now;
  window.speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.rate=1.05; u.pitch=1.0; u.volume=0.9;
  const voices=window.speechSynthesis.getVoices();
