/* в”Ђв”Ђ HEATMAP в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
function updateHeatmap(){
  const ex=EXERCISES[curEx];
  for(const rule of ex.formRules){
    for(const rid of rule.regions){
      if(!hmAccum[rid]) hmAccum[rid]={bad:0,total:0};
      hmAccum[rid].total++;
      if(badJoints.has(rule.id)) hmAccum[rid].bad++;
    }
  }
  for(const [rid,d] of Object.entries(hmAccum)){
    const el=document.getElementById(rid);
    if(!el) continue;
    const frac=d.total>8?d.bad/d.total:0;
    el.setAttribute('fill', frac<0.04?'none':heatColor(frac));
  }
}
function resetHeatmap(){
  for(const k in hmAccum) delete hmAccum[k];
  document.querySelectorAll('#hmRegions [id^="hm-"]').forEach(el=>el.setAttribute('fill','none'));
}

/* в”Ђв”Ђ RESET в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
